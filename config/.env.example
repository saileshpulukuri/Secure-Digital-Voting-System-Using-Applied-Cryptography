# Copy to project root as `.env` and adjust values. Never commit real secrets.

JWT_SECRET=replace-with-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password

# When true, each server start sets the admin password for ADMIN_USERNAME from ADMIN_PASSWORD (fixes “invalid credentials” after changing .env)
SYNC_ADMIN_FROM_ENV=true

# Optional: fix election window (ISO 8601, Z suffix recommended)
# ELECTION_STARTS_AT=2026-04-01T00:00:00Z
# ELECTION_ENDS_AT=2026-04-30T23:59:59Z

# Optional: SQLite path (default: ./data/voting.db)
# DATABASE_PATH=/absolute/path/to/voting.db

# Optional: data directory for SQLite default path + uploads (default: ./data)
# DATA_DIR=/absolute/path/to/data
