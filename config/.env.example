# Copy to project root as `.env` and adjust values. Never commit real secrets.

JWT_SECRET=replace-with-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password
# Recovery (admin signed in): POST /api/admin/voters/delete with JSON {"voter_id":"student@umsystem.edu"}
# removes that voter row so they can Register again with a new password (cascades OTPs / registrations / votes).
# Comma-separated; only these may register. Example: spc7p, sgwwp, ts8md, bayd6 @umsystem.edu
STUDENT_EMAIL_ALLOWLIST=spc7p@umsystem.edu,sgwwp@umsystem.edu,ts8md@umsystem.edu,bayd6@umsystem.edu
OTP_EXPIRE_SECONDS=300
# OTP delivery: demo = log only; smtp = send real email (set SMTP_* below).
OTP_DELIVERY_MODE=demo
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=your-college-mail@umsystem.edu
SMTP_PASSWORD=your-app-password-or-smtp-password
SMTP_FROM_EMAIL=your-college-mail@umsystem.edu
SMTP_USE_STARTTLS=true
# Demo convenience only. Set false in production. Ignored when OTP_DELIVERY_MODE=smtp.
EXPOSE_OTP_IN_RESPONSE=true

# When true, each server start sets the admin password for ADMIN_USERNAME from ADMIN_PASSWORD (fixes “invalid credentials” after changing .env)
SYNC_ADMIN_FROM_ENV=true

# Optional: fix election window (ISO 8601, Z suffix recommended)
# ELECTION_STARTS_AT=2026-04-01T00:00:00Z
# ELECTION_ENDS_AT=2026-04-30T23:59:59Z

# Optional: SQLite path (default: ./data/voting.db)
# DATABASE_PATH=/absolute/path/to/voting.db

# Optional: data directory for SQLite default path + uploads (default: ./data)
# DATA_DIR=/absolute/path/to/data
